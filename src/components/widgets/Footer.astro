---
import { Icon } from 'astro-icon/components';
import { SITE } from '~/utils/config';
import { getHomePermalink } from '~/utils/permalinks';
import Logo from "~/assets/images/logo-tchad.jpg";
import { Image } from "astro:assets";

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links: Array<Links>;
  secondaryLinks: Array<Link>;
  socialLinks: Array<Link>;
  theme?: string;
}

const { socialLinks = [], secondaryLinks = [], links = [], theme = 'light' } = Astro.props;
---

<footer class:list={[{ dark: theme === 'dark' }, 'relative border-t border-gray-200 dark:border-slate-800 not-prose bg-white dark:bg-slate-900']}>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- TOP -->
    <div class="grid grid-cols-12 gap-8 py-10">

      <!-- LOGO + DESCRIPTION -->
      <div class="col-span-12 lg:col-span-4">
        <a class="inline-block mb-4" href={getHomePermalink()}>
          <Image src={Logo} alt="Logo CitizenLab" width={160} height={50} />
        </a>

        <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed max-w-md">
          AfricTivistes CitizenLab œuvre pour promouvoir la participation citoyenne,
          la transparence et l’engagement démocratique à travers l’innovation numérique.
        </p>

        <!-- Secondary Links (inchangés) -->
        <div class="mt-4 text-sm">
          {
            secondaryLinks.map(({ text, href }) => (
              <a
                class="text-gray-500 hover:text-gray-800 dark:text-gray-400 dark:hover:text-white transition mr-3"
                href={href}
                set:html={text}
              />
            ))
          }
        </div>
      </div>

      <!-- LINKS DYNAMIQUES (inchangés) -->
      {
        links.map(({ title, links }) => (
          <div class="col-span-6 md:col-span-3 lg:col-span-2">
            <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-200 mb-4">
              {title}
            </h3>
            {links?.length > 0 && (
              <ul class="space-y-2 text-sm">
                {links.map(({ text, href, ariaLabel }) => (
                  <li>
                    <a
                      class="text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white transition"
                      href={href}
                      aria-label={ariaLabel}
                    >
                      <Fragment set:html={text} />
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))
      }
    </div>

    <!-- BOTTOM -->
    <div class="border-t border-gray-200 dark:border-slate-700 py-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">

      <!-- SOCIAL (inchangé) -->
      {
        socialLinks?.length ? (
          <ul class="flex space-x-2">
            {socialLinks.map(({ ariaLabel, href, icon }) => (
              <li>
                <a
                  class="text-gray-500 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-slate-700 rounded-lg p-2 transition"
                  aria-label={ariaLabel}
                  href={href}
                  target="_blank"
                >
                  {icon && <Icon name={icon} class="w-5 h-5" />}
                </a>
              </li>
            ))}
          </ul>
        ) : null
      }

      <!-- TEXTE INSTITUTIONNEL -->
      <p class="text-xs text-gray-500 dark:text-gray-400 leading-relaxed max-w-3xl">
        Ce site web a été créé grâce au soutien du <strong>Digital Democracy Initiative</strong>
        dans le cadre du projet <strong>Digitalise Youth</strong> et s’inscrit dans le programme
        <strong>AfricTivistes CitizenLab</strong>, conçu et géré par <strong>AfricTivistes</strong>.
      </p>

    </div>

  </div>
</footer>
